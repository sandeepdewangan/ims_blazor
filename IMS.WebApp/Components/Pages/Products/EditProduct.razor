@page "/editproduct/{productId:int}"
@attribute [Authorize]
@using IMS.WebApp.Components.Controls
@rendermode InteractiveServer

@inject IProductRepository ProductRepo
@inject NavigationManager NavManager

<h3>Edit Product</h3>

@if (product is not null)
{
    <EditForm Model="product" OnValidSubmit="Update">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <InputNumber @bind-Value="product.ProductId" hidden />

        <div class="form-group">
            <label for="name">Product Name</label>
            <InputText id="name" @bind-Value="product.ProductName" class="form-control" />
            <ValidationMessage For="() => product.ProductName" />
        </div>
        <div class="form-group">
            <label for="quantity">Quantity</label>
            <InputNumber id="quantity" @bind-Value="product.Quantity" class="form-control" />
            <ValidationMessage For="() => product.Quantity" />
        </div>
        <div class="form-group">
            <label for="price">Price</label>
            <InputNumber id="price" @bind-Value="product.Price" class="form-control" />
            <ValidationMessage For="() => product.Price" />
        </div>
        <hr/>
        <div>
            <ProductInventoriesComponent Product="this.product"/>
        </div>
        <br />
        <button type="submit" class="btn btn-primary">Update</button>
        &nbsp;
        @* This will not cause a full page reload to the /inventories because of enhance navigation *@
        <a href="/products" class="btn btn-outline-danger">Cancel</a>
    </EditForm>
}

@code {

    [Parameter]
    public int ProductId { get; set; }

    [SupplyParameterFromForm]
    private Product? product { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        this.product = this.product ?? await ProductRepo.GetProductByIdAsync(this.ProductId);

        if(this.product is null)
        {
            NavManager.NotFound();
        }
    }

    private async Task Update()
    {
        if(product is not null)
        {
            await ProductRepo.EditProductAsync(product);
            NavManager.NavigateTo("/products");
        }
    }

}
